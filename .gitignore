
---

## 📁 2. Fichier `.gitignore` (mis à jour)

```gitignore
# ============================================================
# ENVIRONNEMENT VIRTUAL
# ============================================================
venv/
.env/
.venv/
env/
ENV/
virtualenv/
.python-version

# ============================================================
# FICHIERS PYTHON
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# ============================================================
# BASE DE DONNÉES (SQLite)
# ============================================================
db/*.db
*.db
*.sqlite
*.sqlite3
!db/.gitkeep

# ============================================================
# LOGS
# ============================================================
logs/
*.log
*.out
*.err

# ============================================================
# SAUVEGARDES
# ============================================================
backups/
*.bak
*.backup

# ============================================================
# FICHIERS DE DONNÉES GÉNÉRÉS PAR L'APPLICATION
# ============================================================
commandes.csv
depenses.csv
export_*.csv
export_*.xlsx
recus/*.pdf
recus/
*.pdf
!recus/.gitkeep

# ============================================================
# FICHIERS TEMPORAIRES
# ============================================================
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
*.lock
*.cache
*.pid

# ============================================================
# ÉDITEURS ET IDE
# ============================================================
.vscode/
.idea/
*.iml
*.iws
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.atom/
.apm/

# ============================================================
# SYSTÈME D'EXPLOITATION
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride
._*

# ============================================================
# RAPPORTS ET EXPORTS
# ============================================================
rapport_*.pdf
*.report
coverage.xml
*.xlsx

# ============================================================
# CONFIGURATION PERSONNELLE
# ============================================================
.env
.env.local
config.local.py
settings_local.py
*.secret
*.key
*.pem
*.crt
*.cer

# ============================================================
# AUTRES
# ============================================================
*.zip
*.tar.gz
*.rar
*.7z
*.gz
*.bz2
.DS_Store
*.orig
*.rej